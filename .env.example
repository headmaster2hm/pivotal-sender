# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Only emails from this domain can be used in the From field (server-side enforcement)
ALLOWED_FROM_DOMAIN=pivotalphilanthropyprogram.com

# Pre-fill the From field in the composer UI
NEXT_PUBLIC_DEFAULT_FROM_EMAIL=contactus@pivotalphilanthropyprogram.com

# Must match ALLOWED_FROM_DOMAIN — used for client-side validation hints
NEXT_PUBLIC_ALLOWED_FROM_DOMAIN=pivotalphilanthropyprogram.com
